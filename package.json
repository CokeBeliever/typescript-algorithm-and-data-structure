  "homepage": "https://github.com/CokeBeliever/typescript-algorithm-and-data-structure#readme",
  "devDependencies": {
    "@types/jest": "^29.2.5",
    "jest": "^29.3.1",
    "prettier": "^2.7.1",
    "ts-jest": "^29.0.3",
    "typescript": "^4.9.4"
  }
